#!/usr/bin/env sh
':' <<'__NOT_PHP__'
<?php
// sh/PHP polyglot guard. `sh` treats the block above as a no-op heredoc and skips it; running
// this file with PHP by mistake (`php lemma`) lands here and prints a hint instead of dumping
// the whole script. (PHP ignores the `#!` shebang, so only the harmless `: <<...` line shows.)
fwrite(STDERR, "lemma is a shell launcher — run it as './lemma <command>', not 'php lemma'.\n");
exit(1);
// __halt_compiler() stops PHP tokenizing here, so the sh code below is never parsed.
__halt_compiler();
__NOT_PHP__
# lemma — branded operator front door for a Lemma instance.
# A thin sh launcher that forwards to the app's own `php glueful` console (which owns the real
# lemma:provision / lemma:create-admin / lemma:doctor commands). Run it as `./lemma <command>`.
set -e

# Resolve this script's real location, following symlinks, so `lemma` can be symlinked onto
# $PATH (e.g. /usr/local/bin/lemma) and still find its sibling `glueful`. macOS has no
# `readlink -f`, so walk the symlink chain portably.
SOURCE="$0"
while [ -h "$SOURCE" ]; do
  link_dir="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in
    /*) ;;                       # absolute target — use as-is
    *) SOURCE="$link_dir/$SOURCE" ;;  # relative target — resolve against the link's dir
  esac
done
DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PHP="${PHP:-php}"
GLUEFUL="$DIR/glueful"

cmd="${1:-}"
[ "$#" -gt 0 ] && shift || true

# Every word is quoted so a $DIR (or any arg) containing spaces is passed intact.
case "$cmd" in
  "" | -h | --help | help)
    # Only advertise what THIS launcher can run: the lemma:* namespace + the shortcuts below.
    # (`php glueful` is the full framework console.)
    printf '%s\n' \
      'lemma — operator CLI for this Lemma instance.' \
      '' \
      'Run any command below as `lemma <name>` (the `lemma:` prefix is optional).' \
      'Shortcuts: `lemma setup` (provision + create-admin), `lemma migrate`, `lemma key:generate`.' \
      'For the full framework console, use `php glueful`.' \
      '' \
      'Commands:'
    # --raw drops Symfony's generic Usage/Options preamble — just the lemma:* command lines.
    exec "$PHP" "$GLUEFUL" list lemma --raw
    ;;
  setup)
    # The interactive front door: run the two setup layers as TWO processes. Layer 2
    # (create-admin) MUST be a fresh boot so its container-bound DB connection reflects the
    # .env that Layer 1 (provision) just wrote. No flags are forwarded — for non-interactive
    # use, call `lemma provision` and `lemma create-admin` directly with their options.
    "$PHP" "$GLUEFUL" lemma:provision && exec "$PHP" "$GLUEFUL" lemma:create-admin
    ;;
  migrate)
    exec "$PHP" "$GLUEFUL" migrate:run "$@"
    ;;
  key:generate)
    exec "$PHP" "$GLUEFUL" generate:key "$@"
    ;;
  lemma:*)
    # Tolerate a redundant prefix: `lemma lemma:doctor` == `lemma doctor`.
    exec "$PHP" "$GLUEFUL" "$cmd" "$@"
    ;;
  *)
    # provision, create-admin, doctor, and any other lemma:<cmd>
    exec "$PHP" "$GLUEFUL" "lemma:$cmd" "$@"
    ;;
esac
