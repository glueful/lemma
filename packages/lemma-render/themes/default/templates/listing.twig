{% extends 'layout.twig' %}
{% block title %}{{ type }} — {{ site.name }}{% endblock %}
{% block content %}
  <h1>{{ type }}</h1>
  <ul class="listing">
    {% for item in items %}
      <li>
        {% if item.href %}
          <a href="{{ item.href }}">{{ item.fields.title|default(item.uuid) }}</a>
        {% else %}
          {{ item.fields.title|default(item.uuid) }}
        {% endif %}
      </li>
    {% else %}
      <li class="empty">No entries yet.</li>
    {% endfor %}
  </ul>
  {% include '_pagination.twig' %}
{% endblock %}
